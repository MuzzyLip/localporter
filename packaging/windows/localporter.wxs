<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
      Name="LocalPorter"
      Manufacturer="LocalPorter"
      Version="$(var.ProductVersion)"
      UpgradeCode="1F5EC46B-3A64-4C93-8A43-6227EFA3432B"
      Scope="perUser"
      Language="1033"
      InstallerVersion="500"
      Compressed="yes">
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="AppIcon.ico" SourceFile="$(var.AppIconPath)" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <ui:WixUI Id="WixUI_Minimal" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="InstallRoot" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="LocalPorter" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="LocalPorter" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="LocalPorter" Level="1">
      <ComponentGroupRef Id="AppComponents" />
    </Feature>
  </Package>

  <Fragment>
    <ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="*">
        <File Id="AppExe" Source="$(var.AppExePath)" KeyPath="yes" />
        <Shortcut
            Id="StartMenuShortcut"
            Directory="ProgramMenuDir"
            Name="LocalPorter"
            WorkingDirectory="INSTALLFOLDER"
            Target="[INSTALLFOLDER]localporter-app.exe"
            Icon="AppIcon.ico" />
        <RemoveFolder Id="RemoveProgramMenuDir" Directory="ProgramMenuDir" On="uninstall" />
        <RegistryValue
            Root="HKCU"
            Key="Software\LocalPorter"
            Name="Installed"
            Type="integer"
            Value="1" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
